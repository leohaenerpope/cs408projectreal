<div class="container mt-5">
    <div class="card bg-dark text-white shadow">
      <div class="card-header border-primary">
        <h2 class="mb-0 text-center">Player List</h2>
      </div>
      <div class="card-body">        
        <table class="table table-dark table-hover">
          <thead>
            <tr>
              <th>Player Name</th>
              <th>Options</th>
            </tr>
          </thead>

          <tbody>
            <% if (players.length === 0) { %>
              <tr>
                <td colspan="2" class="text-center">No players found</td>
              </tr>
            <% } else { %>
              <% players.forEach(player => { %>
                <tr>
                  <td><%= player.name %></td>
                  <td>
                    <a href="/matchups/<%= player.id %>" class="btn btn-sm btn-outline-info">
                      Matchup Notes
                    </a>
                    <a href="/players/delete/<%= player.id %>" class="btn btn-sm btn-outline-danger">
                      Delete
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>

        </table>
      </div>
    </div>
    <div class="mt-4 text-end">
      <a href="/players/add" class="btn btn-primary btn-lg px-5">
        Add Player
      </a>
    </div>
  </div>