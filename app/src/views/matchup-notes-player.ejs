<div class="container py-5">
    <div class="text-center mb-5">
      <h1 class="display-4 text-white">Matchup Notes For: <span class="text-info"><%= playerName %></span></h1>
    </div>
  
    <div class="card bg-dark text-white shadow-lg border-secondary">
      <div class="card-body p-4">
        
        <div class="row mb-4 align-items-center">
          <div class="col-md-6">
            <label class="form-label fw-bold">Displaying Matchup Notes Against:</label>
            <select class="form-select bg-secondary text-white border-0">
              <option selected>Everyone</option>
              <option value="1">Stephen Curry</option>
            </select>
          </div>
          <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <a href="/matchups/<%= playerSlug %>/add" class="btn btn-success">+ Add New Note</a>
          </div>
        </div>
  
        <hr class="border-secondary">
  
        <div class="matchup-list">
          
          <div class="card bg-dark text-white border-primary mb-4">
            <div class="card-header bg-primary d-flex justify-content-between">
              <span><strong>Against:</strong> Stephen Curry</span>
              <span><strong>Matchup Date:</strong> 2026-03-10</span>
            </div>
            <div class="card-body">
              <div class="row text-center mb-3 border-bottom border-secondary pb-2">
                <div class="col-4"><strong>28</strong> PTS</div>
                <div class="col-4"><strong>8</strong> AST</div>
                <div class="col-4"><strong>4</strong> REB</div>
              </div>
              
              <p class="card-text text-light-50 italic">
                Curry is too small and no match for lebron
              </p>
              
              <div class="mt-3 text-end">
                <a href="/matchups/<%= playerSlug %>/edit/1" class="btn btn-sm btn-outline-warning me-2">Manage</a>
                <button class="btn btn-sm btn-outline-danger">Delete</button>
              </div>
            </div>
          </div>
  
        </div> </div>
    </div>
  </div>