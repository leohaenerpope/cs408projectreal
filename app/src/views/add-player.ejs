<div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card bg-dark text-white shadow-lg">
          <div class="card-header bg-primary text-center">
            <h3 class="mb-0">Add New Player</h3>
          </div>
          <div class="card-body p-4">
            <form action="/players/add" method="POST">
              <div class="mb-3">
                <label class="form-label">Player Name</label>
                <input type="text" name="playerName" class="form-control" placeholder="Enter Player Name..." required>
              </div>

              <div class="d-grid gap-2">
                <button type="submit" class="btn btn-success btn-lg">Create Player</button>
                <a href="/players" class="btn btn-outline-secondary">Cancel</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>