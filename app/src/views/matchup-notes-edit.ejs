<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="text-white">Edit Matchup Note</h2>
      <form action="/matchups/<%= playerSlug %>/delete/<%= note.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this note?');">
        <button type="submit" class="btn btn-outline-danger">Delete Note</button>
      </form>
    </div>
    
    <div class="card bg-dark text-white p-4 shadow-lg border-secondary">
      <form action="/matchups/<%= playerSlug %>/edit/<%= note.id %>" method="POST">
        
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">Matchup Date</label>
            <input type="date" name="matchupDate" value="<%= note.matchupDate %>" class="form-control bg-secondary text-white border-0" required>
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">Opponent Name</label>
            <input type="text" name="opponent" value="<%= note.opponent %>" class="form-control bg-secondary text-white border-0" required>
          </div>
        </div>
  
        <div class="row mb-3 text-center">
          <div class="col-4">
            <label class="form-label">PTS</label>
            <input type="number" name="points" value="<%= note.points %>" class="form-control bg-secondary text-white border-0">
          </div>
          <div class="col-4">
            <label class="form-label">AST</label>
            <input type="number" name="assists" value="<%= note.assists %>" class="form-control bg-secondary text-white border-0">
          </div>
          <div class="col-4">
            <label class="form-label">REB</label>
            <input type="number" name="rebounds" value="<%= note.rebounds %>" class="form-control bg-secondary text-white border-0">
          </div>
        </div>
  
        <div class="mb-4">
          <label class="form-label fw-bold">Matchup Notes</label>
          <textarea name="notes" class="form-control bg-secondary text-white border-0" rows="4"><%= note.notes %></textarea>
        </div>
  
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary px-5">Save Changes</button>
          <a href="/matchups/<%= playerSlug %>" class="btn btn-outline-light">Cancel</a>
        </div>
      </form>
    </div>
  </div>